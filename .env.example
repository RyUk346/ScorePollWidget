# Copy this file to ".env" and fill in your Firebase project values.
# Create a project at https://console.firebase.google.com, add a Web App,
# and enable Realtime Database (in test mode for a quick demo).
# All Vite env vars exposed to the browser MUST be prefixed with VITE_.
#
# Until these hold REAL values (not the "your-..." placeholders), the app runs
# in local demo mode (votes sync across browser tabs only).

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef123456

# Optional. The public base URL the QR code should point to. Set this to your
# deployed domain (e.g. https://your-app.com). If blank, the QR uses the
# address the app is currently served on (window.location.origin).
VITE_PUBLIC_URL=

# For the live-data poller (`npm run poll`). Free key from football-data.org.
# Only the poller uses this — it is NOT prefixed VITE_, so it is never exposed
# to the browser. Optional poll interval in ms (default 20000).
FOOTBALL_DATA_TOKEN=your-football-data-token
POLL_MS=20000

# Competition to poll. Default WC (World Cup). To test live scores BEFORE the
# World Cup starts, set this to a competition in play now (e.g. BSA = Brazil
# Série A, PL, PD, SA) then change it back to WC.
FOOTBALL_DATA_COMPETITION=WC
